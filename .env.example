# Copy to .env and fill in. .env is gitignored.

# --- Proton Bridge connection (mcp-server -> bridge over the compose net) ---
BRIDGE_HOST=protonmail-bridge
BRIDGE_IMAP_PORT=1143
BRIDGE_SMTP_PORT=1025

# Bridge-generated IMAP/SMTP credentials. Get them once via:
#   docker compose run --rm protonmail-bridge bridge --cli
#   > login        (enter Proton email/password/2FA)
#   > info         (copy the username and password shown here)
BRIDGE_USERNAME=
BRIDGE_PASSWORD=

# --- MCP server ---
# Strong random shared secret. Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=
# MCP_HOST is the bind address INSIDE the container (leave as 0.0.0.0).
MCP_HOST=0.0.0.0
# MCP_PORT drives both the in-container listen port and the published host
# port. Change it here if 8080 is taken (e.g. 8081).
MCP_PORT=8080
# Host interface the port is published on. 127.0.0.1 = localhost only.
# Set to 0.0.0.0 to expose on the LAN (put TLS in front if you do).
MCP_BIND=127.0.0.1
